# ---- GateFlow environment template ----
# Copy to .env and fill in real values. NEVER commit .env.
# Rotate any secret that has ever been shared or committed.

# MongoDB connection string (Atlas or self-hosted)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/gateplus
DB_NAME=gateflow

# Public base URL of the deployment
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins. Use exact origins in production
# (e.g. https://gateflow.example.com). '*' disables credentialed CORS.
CORS_ORIGINS=http://localhost:3000

# Token signing secrets — generate with: openssl rand -hex 32
# REQUIRED in production; the app refuses to start without them.
USER_SECRET=
ADMIN_SECRET=

# Optional: initial admin password for the seeded admin@gateplus.local account.
# If unset, a strong random password is generated and printed to the server log
# once on first boot. Change it immediately after first login.
ADMIN_INITIAL_PASSWORD=

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Identity (Sign in with Google)
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
